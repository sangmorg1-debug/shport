{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sangmorg1-debug/shport/raw/main/schema/shport-report-v1.schema.json",
  "title": "shport report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "tool",
    "targets",
    "filesAnalyzed",
    "diagnostics",
    "analysisErrors"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "tool": {
      "$ref": "#/$defs/tool"
    },
    "targets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/profile"
      }
    },
    "filesAnalyzed": {
      "type": "integer",
      "minimum": 0
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    },
    "analysisErrors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/analysisError"
      }
    }
  },
  "$defs": {
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "const": "shport"
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "alias", "description", "references"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "alias": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "references": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "column"],
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {
          "$ref": "#/$defs/position"
        },
        "end": {
          "$ref": "#/$defs/position"
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleId",
        "severity",
        "message",
        "path",
        "range",
        "command",
        "incompatibleTargets"
      ],
      "properties": {
        "ruleId": {
          "type": "string",
          "pattern": "^SP[0-9]{4}$"
        },
        "severity": {
          "const": "warning"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "range": {
          "$ref": "#/$defs/range"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "option": {
          "type": "string"
        },
        "incompatibleTargets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "suggestion": {
          "type": "string"
        },
        "reference": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "analysisError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message"],
      "properties": {
        "path": {
          "type": "string"
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
